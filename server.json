{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.ozten/cantrip",
  "description": "MCP server for Cantrip — AI-powered GTM engine for solo founders",
  "repository": {
    "url": "https://github.com/ozten/mcp-server-cantrip",
    "source": "github"
  },
  "version": "1.0.5",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "mcp-server-cantrip",
      "version": "1.0.5",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "Your Cantrip API key",
          "isRequired": true,
          "format": "string",
          "isSecret": true,
          "name": "CANTRIP_API_KEY"
        }
      ]
    }
  ]
}
